{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "flue-agent",
	"compatibility_date": "2026-06-01",
	"compatibility_flags": ["nodejs_compat"],
	"exports": {
		"FlueHelloWorldAgent": {
			"type": "durable-object",
			"storage": "sqlite"
		},
		"FlueRegistry": {
			"type": "durable-object",
			"storage": "sqlite"
		},
		"FlueTravelAgent": {
			"type": "durable-object",
			"storage": "sqlite"
		},
		"FlueTranslateWorkflow": {
			"type": "durable-object",
			"storage": "sqlite"
		}
	}
}
